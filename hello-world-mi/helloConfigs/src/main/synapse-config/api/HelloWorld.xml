<?xml version="1.0" encoding="UTF-8"?>
<api context="/HelloWorld" name="HelloWorld" xmlns="http://ws.apache.org/ns/synapse">
    <resource methods="GET">
        <inSequence>
            <!-- Getting env variables -->
            <property expression="get-property('env', 'TOKEN_URL')" name="token_url"
                scope="default" type="STRING" />
            <property expression="get-property('env', 'CONSUMER_KEY')" name="consumer_key"
                scope="default" type="STRING" />
            <property expression="get-property('env', 'CONSUMER_SECRET')"
                name="uri.var.consumer_secret"
                scope="default" type="STRING" />
            <property expression="get-property('env', 'SVC_URL')" name="service_url"
                scope="default" type="STRING" />

            <payloadFactory media-type="json">
                <format>{"service_url":"$1"}</format>
                <args>
                    <arg evaluator="xml" expression="get-property('service_url')"/>
                </args>
            </payloadFactory>

            <respond />
        </inSequence>
        <outSequence />
        <faultSequence />
    </resource>
</api>
